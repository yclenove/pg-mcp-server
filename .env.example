# 复制为 .env 并填写；勿将 .env 提交到 Git
#
# 方式 A：分项配置
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=your_user
PG_PASSWORD=your_password
PG_DATABASE=your_database
# 可选：限制可切换/可列举的库（逗号分隔，仅字母数字下划线）；不设置则不限制
# PG_DATABASE_ALLOWLIST=db1,db2
#
# MCP：schema/overview 资源最多展开多少张表的列（默认 50；0=仅表名）
# MCP_SCHEMA_OVERVIEW_MAX_TABLES=50
#
# 多 DSN（JSON 数组）；默认连接仍为上面 PG_* / PG_URL
# PG_MCP_EXTRA_CONNECTIONS=[{"id":"replica","url":"postgresql://user:pass@127.0.0.1:5432/db"}]
# PG_MCP_CONNECTION_ID=default
#
# 运维工具（可选）
# PG_MCP_OPS_TOOLS=false
# PG_MCP_KILL_QUERY=false
# PG_MCP_READ_AUDIT_TOOL=false
# PG_MCP_PROCESS_LIST_MAX=100
# PG_MCP_READ_SLOW_LOG=false
# PG_MCP_SLOW_LOG_PATH=/var/log/postgresql/postgresql.log
#
# 只读时会话级 transaction_read_only（PG_READONLY=true 时自动）
# 额外 DSN 默认库与白名单：PG_MCP_VALIDATE_EXTRA_CONNECTIONS=true
# MCP_QUERY_RESULT_HINT=true
# PG_MCP_EXPLAIN_JSON=true
#
# 方式 B：连接串（与方式 A 二选一即可；密码含特殊字符请 URL 编码）
# PG_URL=postgresql://user:password@127.0.0.1:5432/your_database
# 或与部分生态兼容的别名：
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/your_database
